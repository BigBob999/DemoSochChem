<Window x:Class="DemoSochChem.Views.Windows.AddEditManufacture"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoSochChem.Views.Windows"
        mc:Ignorable="d"
            Title="Добавить/Редактировать данные производства" SizeToContent="WidthAndHeight" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="21">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>


        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <TextBlock Text="Материал:"/>
        <ComboBox Name="MaterialCmb" Text="{Binding Material.ItemId}" Grid.Column="2" Grid.Row="0"/>

      

        <TextBlock Text="Артикул:" Grid.Row="2"/>
        <TextBox Name="CodeTb" Grid.Column="2" Text="{Binding Code}" Grid.Row="2"/>

        

        <CheckBox Name="IsProductCb" IsChecked="{Binding IsProduct}" Grid.Column="2" Grid.Row="4" Content="Товар"/>



        <Button Name="EditManufactureBtn" Grid.Row="12" Grid.Column="2" Content="Редактировать" Visibility="Hidden" Click="EditManufactureBtn_Click"/>
        <Button Name="AddManufactureBtn" Content="Добавить производство" Grid.Row="12" Grid.Column="2" Visibility="Visible" Click="AddManufactureBtn_Click"/>

    </Grid>
</Window>
