<Window x:Class="DemoSochChem.Views.Windows.AddEditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoSochChem.Views.Windows"
        mc:Ignorable="d"
            Title="Добавить/Редактировать данные заказа" SizeToContent="WidthAndHeight" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="21">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>


        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <TextBlock Text="Номер:"/>
        <TextBox Name="NumTb" Text="{Binding Number}" Grid.Column="2" Grid.Row="0"/>

        <TextBlock Text="Дата:" Grid.Row="2"/>
        <DatePicker Name="DateDp" Text="{Binding Date}" Grid.Column="2" Grid.Row="2"/>

        <TextBlock Text="Сумма:" Grid.Row="4"/>
        <TextBox Name="AmountTb" Grid.Column="2" Text="{Binding TotalPrice}" Grid.Row="4"/>
        
        <Button Name="EditOrderBtn" Grid.Row="12" Grid.Column="2" Content="Редактировать" Visibility="Hidden" Click="EditOrderBtn_Click"/>
        <Button Name="AddOrderBtn" Content="Добавить заказ" Grid.Row="12" Grid.Column="2" Visibility="Visible" Click="AddOrderBtn_Click"/>

    </Grid>
</Window>
