<Page x:Class="DemoSochChem.Views.Pages.ManufacturePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DemoSochChem.Views.Pages"
      mc:Ignorable="d" 
        d:DesignHeight="784" d:DesignWidth="1560"
  Title="Производство">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="20" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="20" />

                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>
            <Button Name="AddManufacture" Click="AddManufacture_Click" Grid.Column="0" Content="Добавить" />
            <Button Name="EditManufacture" Click="EditManufacture_Click" Grid.Column="2" Content="Редактировать" />
            <Button Name="RemoveManufacture" Click="RemoveManufacture_Click" Grid.Column="4" Content="Удалить" />
            <TextBlock Grid.Column="8" Text="Поиск:"/>
            <TextBox Name="SearchTb" Grid.Column="10" TextChanged="SearchTb_TextChanged"/>

            <TextBlock Grid.Column="12" Text="Фильтр:"/>
            <ComboBox Grid.Column="14" Name="FilterCmb" SelectionChanged="FilterCmb_SelectionChanged"/>
        </Grid>
        <ListView Name="ManufactureLv" Grid.Row="2">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Материал" DisplayMemberBinding="{Binding ItemId}"/>
                    <GridViewColumn Header="Тип товара" DisplayMemberBinding="{Binding IsProduct1}"/>
                    <GridViewColumn Header="Артикул" DisplayMemberBinding="{Binding Code}"/>
                   
                </GridView>
            </ListView.View>
        </ListView>

    </Grid>
</Page>
